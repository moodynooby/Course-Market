# Course Hub - Environment Configuration

# ===============================
# LLM Configuration
# ===============================

# Local LLM (Ollama) - for server-side optimization
VITE_LLM_ENDPOINT=http://localhost:11434/api/chat

# WebLLM - Browser-based AI (uses local GPU if available)
# No endpoint needed - runs entirely in browser
VITE_WEBLLM_ENABLED=true
VITE_WEBLLM_MODEL=Phi-3-mini-4k-instruct-q4f16_1

# ===============================
# Netlify Configuration
# ===============================

# Netlify Function URL for Trading Board
VITE_NETLIFY_FUNCTION_URL=https://your-site.netlify.app/.netlify/functions

# Database URL (for Netlify Functions with Neon PostgreSQL)
DATABASE_URL=your_neon_database_url_here
NEON_DATABASE_URL=your_neon_database_url_here

# ===============================
# Firebase Configuration
# ===============================

# Add your Firebase config for OAuth
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id

# ===============================
# Development Notes
# ===============================

# 1. WebLLM: No server needed - runs in browser using WebGPU
#    - Works in Chrome/Edge with WebGPU support
#    - Downloads model on first use (~2GB)
#    - Privacy-focused: data stays in browser

# 2. Local LLM (Ollama): Requires local server
#    - Install Ollama: https://ollama.ai/
#    - Run: ollama serve
#    - Pull model: ollama pull llama3.2

# 3. Database: Uses localStorage fallback when unavailable
#    - Set DATABASE_URL for persistent PostgreSQL storage
#    - Works without database using browser localStorage