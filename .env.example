# Local LLM Endpoint Configuration
# Set this to your local LLM endpoint (e.g., Ollama, LM Studio)
# Examples:
# - Ollama: http://localhost:11434/api/chat
# - LM Studio: http://localhost:1234/v1/chat/completions
VITE_LLM_ENDPOINT=http://localhost:11434/api/chat

# Netlify Function URL for Trading Board
# Set this when deploying to Netlify with database functionality
VITE_NETLIFY_FUNCTION_URL=https://your-site.netlify.app/.netlify/functions

# Database Configuration (for Netlify Functions)
# Set these when using Neon/PostgreSQL with Netlify functions
DATABASE_URL=your_neon_database_url_here
NEON_DATABASE_URL=your_neon_database_url_here

# Development Notes:
# - If VITE_NETLIFY_FUNCTION_URL is not set, the app will use localStorage fallback
# - If LLM endpoint is not available, the app will use deterministic scheduling
# - For local development without Netlify, set VITE_NETLIFY_FUNCTION_URL to empty string