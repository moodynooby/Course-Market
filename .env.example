# AuraIsHub - Environment Configuration
# Copy this file to .env and fill in your actual values

# ===============================
# Auth0 Configuration (REQUIRED)
# ===============================

# Frontend variables (VITE_ prefix required for browser access)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here
VITE_AUTH0_AUDIENCE=https://your-custom-api-identifier

# Backend variables (no prefix, used by Netlify Functions)
# These should match the VITE_ values above
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-custom-api-identifier

# ===============================
# LLM Providers (Cloud)
# ===============================

# Required for Groq cloud fallback
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# DATABASE_URL is automatically provided by Netlify's Neon addon
# You don't need to set this manually when using Vite plugin
# For manual setup: postgresql://user:pass@host/db
# DATABASE_URL=
