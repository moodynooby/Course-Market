{
  "name": "auraishub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx netlify dev",
    "build": "tsc -b && vite build && echo '/*  /index.html  200' > dist/_redirects",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "biome check --write .",
    "lint:staged": "biome check --write --staged --no-errors-on-unmatched",
    "test": "vitest run",
    "test:fast": "vitest run --exclude '**/*.slow.test.ts'",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "pre-commit": "pnpm run lint:staged && pnpm run typecheck && pnpm run test:fast",
    "setup:hooks": "npx lefthook install",
    "db:generate": "npx netlify dev:exec drizzle-kit generate",
    "db:push": "npx netlify dev:exec drizzle-kit push",
    "db:check": "npx netlify dev:exec drizzle-kit check",
    "db:studio": "npx netlify dev:exec drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@auth0/auth0-react": "^2.16.2",
    "@browser-ai/web-llm": "^2.1.7",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@netlify/neon": "^0.1.2",
    "@netlify/vite-plugin": "^2.12.5",
    "ai": "^6.0.184",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "idb": "^8.0.3",
    "jose": "^6.2.3",
    "minisearch": "^7.2.0",
    "react": "^19.2.6",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "react-virtuoso": "^4.18.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.9.0",
    "lefthook": "^2.1.6",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "workspaces": [
    "."
  ]
}
