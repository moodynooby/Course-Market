{
  "name": "auraishub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && echo '/*  /index.html  200' > dist/_redirects",
    "preview": "vite preview",
    "fix": "biome lint --write . && biome format --write .",
    "check": "bun run fix && tsc -b && vitest run",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "netlify dev:exec drizzle-kit migrate",
    "db:studio": "netlify dev:exec drizzle-kit studio"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.15.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mlc-ai/web-llm": "^0.2.82",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@netlify/neon": "^0.1.2",
    "@netlify/vite-plugin": "^2.11.2",
    "@wllama/wllama": "^2.3.7",
    "date-fns": "^4.1.0",
    "detect-gpu": "^5.0.70",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.2",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.4",
    "lefthook": "^2.1.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
