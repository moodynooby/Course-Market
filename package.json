{
  "name": "auraishub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "npx netlify dev",
    "build": "tsc -b && vite build && echo '/*  /index.html  200' > dist/_redirects",
    "fix": "biome lint --write . && biome format --write .",
    "ci": " bun run fix && vitest run && tsc -b ",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx netlify dev:exec drizzle-kit migrate",
    "db:studio": "npx netlify dev:exec drizzle-kit studio"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.15.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mlc-ai/web-llm": "^0.2.81",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@netlify/neon": "^0.1.2",
    "@wllama/wllama": "^2.3.7",
    "date-fns": "^4.1.0",
    "detect-gpu": "^5.0.70",
    "drizzle-orm": "^0.41.0",
    "jose": "^6.1.3",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.11",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.7.0",
    "lefthook": "^2.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
