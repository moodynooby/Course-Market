          "correctness": {
            "noSwitchDeclarations": "off",
            "noUnusedVariables": "off",
            "useExhaustiveDependencies": "warn",
            "useHookAtTopLevel": "error"
          },
          "style": {
            "noRestrictedGlobals": {
              "level": "error",
              "options": {
                "deniedGlobals": {
                  "import": "Use ENV from src/config instead of import.meta.env",
                  "process": "Use ENV from src/config instead of process.env"
                }
              }
            },
            "useConst": "warn"
          },
          "suspicious": {
            "noConsole": { "level": "warn", "options": { "allow": ["warn", "error"] } },
            "noEmptyBlockStatements": "off",
            "noExplicitAny": "warn"
          }
        }
      }
    },
